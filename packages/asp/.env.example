# Frisk ASP configuration

# Network the ASP settles on: mainnet (X Layer 196) or testnet (X Layer 1952)
FRISK_NETWORK=testnet

# Frisk's attestation signing key (32-byte hex). Required to emit signed verdicts.
FRISK_SIGNER_PK=

# Address that receives x402 payments for the paid /v1/preflight route.
FRISK_PAYTO=

# Deployed FriskRegistry address (EIP-712 verifyingContract + on-chain anchor target).
FRISK_REGISTRY_ADDR=

# Optional custom RPC (defaults to the public X Layer RPC for the chosen network).
XLAYER_RPC=

# Optional: enables the LLM layer of the task-injection detector. Heuristics run without it.
ANTHROPIC_API_KEY=

# Set to 1 to serve /v1/preflight for free (local demos / CI). Off in production.
FRISK_DEV_BYPASS=

# Per-call price for the paid route.
FRISK_PRICE=$0.05

PORT=8080
